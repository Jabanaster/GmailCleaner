APP_ENV=development
PUBLIC_API_BASE_URL=http://localhost:5273
ALLOWED_WEB_ORIGINS=http://localhost:5173
ALLOWED_EXTENSION_IDS=replace_with_unpacked_extension_id
JWT_ISSUER=google-email-organizer-api
JWT_AUDIENCE=google-email-organizer-extension
JWT_SIGNING_SECRET=generate_at_least_32_random_characters
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_TOKEN_TTL_SECONDS=2592000
PAIRING_CODE_TTL_SECONDS=600

# Existing application configuration
DBE91F0215_DATABASE_URL=postgresql://user:password@host/database
GOOGLE_OAUTH_CLIENT_ID=replace_me
GOOGLE_OAUTH_CLIENT_SECRET=replace_me
GEMINI_WORKSHOP_API_KEY=replace_me

# Fernet key for encrypting dashboard refresh tokens (generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
OAUTH_TOKEN_ENCRYPTION_KEY=replace_with_32_byte_base64_encoded_key

# Scan pacing and quota backoff configuration
SCAN_BATCH_SIZE=10
SCAN_BATCH_DELAY_MS=1000
GMAIL_QUOTA_BACKOFF_MS=5000
GMAIL_MAX_RETRY_ATTEMPTS=3


